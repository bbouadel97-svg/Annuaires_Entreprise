<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AnnuaireEntreprise.MainPage"
             Title="Annuaire Entreprise">

    <Grid RowDefinitions="2*,3*" Padding="20">
        <ScrollView Grid.Row="0">
        <VerticalStackLayout Spacing="10" Padding="0,0,0,16">
            <Label Text="Annuaire Entreprise" FontSize="28" FontAttributes="Bold" />
            <Label Text="Gestion des salaries" FontSize="14" TextColor="Gray" />

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Button x:Name="AdminModeButton"
                        Grid.Column="0"
                        IsVisible="False"
                        Text="Activer mode admin"
                        Clicked="OnToggleAdminModeClicked" />
                <Label x:Name="AdminModeLabel"
                       Grid.Column="1"
                       VerticalTextAlignment="Center"
                       Text="Mode visiteur actif"
                       TextColor="#B00020" />
            </Grid>

            <Entry x:Name="SearchEntry"
                   Placeholder="Rechercher par nom"
                   TextChanged="OnSearchTextChanged" />

            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Always">
                <HorizontalStackLayout Spacing="10">
                    <Button Text="Actualiser" Clicked="OnRefreshClicked" />
                    <Button Text="Vider" Clicked="OnClearSearchClicked" />
                    <Button x:Name="ImportApiButton" Text="Importer API" Clicked="OnImportApiClicked" />
                    <Button x:Name="AddButton" Text="Ajouter" Clicked="OnAddClicked" />
                    <Button x:Name="ExportPdfButton"
                            Text="Exporter DB en PDF"
                            Clicked="OnExportDbPdfClicked" />
                </HorizontalStackLayout>
            </ScrollView>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Picker x:Name="SiteFilterPicker"
                        Grid.Column="0"
                        Title="Filtrer par site"
                        ItemDisplayBinding="{Binding Ville}"
                        SelectedIndexChanged="OnSiteFilterChanged" />
                <Picker x:Name="ServiceFilterPicker"
                        Grid.Column="1"
                        Title="Filtrer par service"
                        ItemDisplayBinding="{Binding Nom}"
                        SelectedIndexChanged="OnServiceFilterChanged" />
            </Grid>

            <Label x:Name="DbPathLabel"
                   FontSize="12"
                   TextColor="Gray"
                   LineBreakMode="TailTruncation" />

            <Grid x:Name="AddFormTopGrid" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Entry x:Name="NomEntry" Grid.Column="0" Placeholder="Nom" />
                <Entry x:Name="PrenomEntry" Grid.Column="1" Placeholder="Prenom" />
                <Entry x:Name="EmailEntry" Grid.Column="2" Placeholder="Email" />
            </Grid>

            <Grid x:Name="AddFormBottomGrid" ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                <Entry x:Name="FixeEntry" Grid.Column="0" Placeholder="Tel fixe" />
                <Entry x:Name="PortableEntry" Grid.Column="1" Placeholder="Tel portable" />
                <Picker x:Name="ServicePicker" Grid.Column="2" Title="Service" ItemDisplayBinding="{Binding Nom}" />
                <Picker x:Name="SitePicker" Grid.Column="3" Title="Site" ItemDisplayBinding="{Binding Ville}" />
            </Grid>

            <Button x:Name="UpdateButton"
                    Text="Mettre a jour salarie selectionne"
                    Clicked="OnUpdateSalarieClicked" />

            <Border x:Name="AdminPanel"
                    StrokeThickness="1"
                    Stroke="#C9C9C9"
                    StrokeShape="RoundRectangle 8"
                    Padding="10"
                    IsVisible="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Panneau de gestion admin" FontAttributes="Bold" />

                    <Grid ColumnDefinitions="2*,2*,Auto,Auto,Auto" ColumnSpacing="8">
                        <Picker x:Name="SiteAdminPicker" Grid.Column="0" Title="Sites" ItemDisplayBinding="{Binding Ville}" SelectedIndexChanged="OnSiteAdminSelectionChanged" />
                        <Entry x:Name="SiteVilleEntry" Grid.Column="1" Placeholder="Ville" />
                        <Button Grid.Column="2" Text="Ajouter" Clicked="OnAddSiteClicked" />
                        <Button Grid.Column="3" Text="Modifier" Clicked="OnUpdateSiteClicked" />
                        <Button Grid.Column="4" Text="Supprimer" Clicked="OnDeleteSiteClicked" />
                    </Grid>

                    <Grid ColumnDefinitions="2*,2*,Auto,Auto,Auto" ColumnSpacing="8">
                        <Picker x:Name="ServiceAdminPicker" Grid.Column="0" Title="Services" ItemDisplayBinding="{Binding Nom}" SelectedIndexChanged="OnServiceAdminSelectionChanged" />
                        <Entry x:Name="ServiceNomEntry" Grid.Column="1" Placeholder="Nom service" />
                        <Button Grid.Column="2" Text="Ajouter" Clicked="OnAddServiceClicked" />
                        <Button Grid.Column="3" Text="Modifier" Clicked="OnUpdateServiceClicked" />
                        <Button Grid.Column="4" Text="Supprimer" Clicked="OnDeleteServiceClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
        </ScrollView>

        <CollectionView Grid.Row="1"
                        Margin="0,20,0,0"
                        ItemsSource="{Binding Salaries}"
                        SelectionMode="Single"
                        SelectionChanged="OnSalarieSelectionChanged">
            <CollectionView.EmptyView>
                <Label Text="Aucun salarie trouve." HorizontalOptions="Center" Margin="0,30,0,0" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="#DDDDDD" StrokeShape="RoundRectangle 8" Margin="0,0,0,8" Padding="10">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                            <Label Grid.Row="0" Grid.Column="0" FontAttributes="Bold" FontSize="16" Text="{Binding NomComplet}" />
                            <Button Grid.Row="0" Grid.Column="1"
                                    Text="Supprimer"
                                    BackgroundColor="#D32F2F"
                                    TextColor="White"
                                    IsVisible="{Binding IsAdminActionsVisible}"
                                    Clicked="OnDeleteClicked"
                                    CommandParameter="{Binding Id}" />
                            <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Email}" />
                            <Label Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Details}" TextColor="Gray" FontSize="12" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
